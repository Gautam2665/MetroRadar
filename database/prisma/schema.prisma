datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum SystemStatus {
  ACTIVE
  INACTIVE
  CONSTRUCTION
  PLANNED
}

enum LineStatus {
  ACTIVE
  SUSPENDED
  MAINTENANCE
  PLANNED
}

enum TractionType {
  THIRD_RAIL
  OVERHEAD_CATENARY
  DIESEL
  OTHER
}

enum SignallingType {
  CBTC
  ATC
  ATP
  MANUAL
}

enum LevelType {
  STREET
  CONCOURSE
  PLATFORM
  BASEMENT
  MEZZANINE
  OTHER
}

enum PlatformStatus {
  ACTIVE
  SUSPENDED
  MAINTENANCE
  PLANNED
}

enum AmenityType {
  ATM
  WASHROOM
  POLICE
  WATER
  CHARGING
  PRAYER
  BABY_CARE
  OTHER
}

enum CommercialSpaceStatus {
  VACANT
  OCCUPIED
  UNDER_MAINTENANCE
}

model System {
  id        String       @id @default(uuid()) @db.Uuid
  code      String       @unique
  name      String
  city      String
  country   String
  timezone  String
  logo      String?
  website   String?
  status    SystemStatus @default(ACTIVE)
  isActive  Boolean      @default(true)
  deletedAt DateTime?    @db.Timestamptz
  createdAt DateTime     @default(now()) @db.Timestamptz
  updatedAt DateTime     @updatedAt @db.Timestamptz
  version   Int          @default(1)

  lines          Line[]
  stations       Station[]
  calendars      Calendar[]
  shapes         Shape[]
  importSessions ImportSession[]

  @@index([name])
  @@map("systems")
}

model Agency {
  id           String    @id @default(uuid()) @db.Uuid
  code         String    @unique
  name         String
  website      String?
  contactEmail String?
  phone        String?
  logo         String?
  isActive     Boolean   @default(true)
  deletedAt    DateTime? @db.Timestamptz
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz
  version      Int       @default(1)

  lines Line[]

  @@index([name])
  @@map("agencies")
}

model AssetOwner {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique
  name      String
  website   String?
  isActive  Boolean   @default(true)
  deletedAt DateTime? @db.Timestamptz
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  version   Int       @default(1)

  lines Line[]

  @@index([name])
  @@map("asset_owners")
}

model Line {
  id           String         @id @default(uuid()) @db.Uuid
  systemId     String         @db.Uuid
  agencyId     String         @db.Uuid
  assetOwnerId String         @db.Uuid
  code         String         @unique
  name         String
  color        String
  status       LineStatus     @default(ACTIVE)
  traction     TractionType
  signalling   SignallingType
  gauge        String?
  length       Float?
  openingDate  DateTime?      @db.Date
  website      String?
  isActive     Boolean        @default(true)
  deletedAt    DateTime?      @db.Timestamptz
  createdAt    DateTime       @default(now()) @db.Timestamptz
  updatedAt    DateTime       @updatedAt @db.Timestamptz
  version      Int            @default(1)

  system     System            @relation(fields: [systemId], references: [id])
  agency     Agency            @relation(fields: [agencyId], references: [id])
  assetOwner AssetOwner        @relation(fields: [assetOwnerId], references: [id])
  sequences  StationSequence[]
  platforms  Platform[]
  trips      Trip[]

  @@index([systemId])
  @@index([agencyId])
  @@index([assetOwnerId])
  @@index([name])
  @@map("lines")
}

model Station {
  id                   String                   @id @default(uuid()) @db.Uuid
  systemId             String                   @db.Uuid
  code                 String                   @unique
  name                 String
  latitude             Float
  longitude            Float
  geom                 Unsupported("geometry(Point, 4326)")?
  timezone             String
  address              String?
  city                 String
  state                String
  country              String
  openingTime          String?
  closingTime          String?
  wheelchairAccessible Boolean                  @default(false)
  parking              Boolean                  @default(false)
  bikeParking          Boolean                  @default(false)
  isActive             Boolean                  @default(true)
  deletedAt            DateTime?                @db.Timestamptz
  createdAt            DateTime                 @default(now()) @db.Timestamptz
  updatedAt            DateTime                 @updatedAt @db.Timestamptz
  version              Int                      @default(1)

  system           System            @relation(fields: [systemId], references: [id])
  sequences        StationSequence[] @relation("StationSequenceStation")
  nextSequences    StationSequence[] @relation("StationSequenceNextStation")
  towardsPlatforms Platform[]        @relation("PlatformTowardsStation")
  levels           Level[]
  entrances        Entrance[]
  amenities        Amenity[]
  commercialSpaces CommercialSpace[]
  stopTimes        StopTime[]
  walkingEdges     WalkingEdge[]

  @@index([systemId])
  @@index([name])
  @@map("stations")
}

model StationSequence {
  id                     String    @id @default(uuid()) @db.Uuid
  lineId                 String    @db.Uuid
  stationId              String    @db.Uuid
  sequence               Int
  distanceFromPrevious   Float
  travelTimeFromPrevious Int
  nextStationId          String?   @db.Uuid
  isActive               Boolean   @default(true)
  deletedAt              DateTime? @db.Timestamptz
  createdAt              DateTime  @default(now()) @db.Timestamptz
  updatedAt              DateTime  @updatedAt @db.Timestamptz
  version                Int       @default(1)

  line        Line     @relation(fields: [lineId], references: [id])
  station     Station  @relation("StationSequenceStation", fields: [stationId], references: [id])
  nextStation Station? @relation("StationSequenceNextStation", fields: [nextStationId], references: [id])

  @@unique([lineId, sequence])
  @@index([lineId])
  @@index([stationId])
  @@index([nextStationId])
  @@map("station_sequences")
}

model Level {
  id          String    @id @default(uuid()) @db.Uuid
  stationId   String    @db.Uuid
  name        String
  levelNumber Int
  type        LevelType
  description String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz
  version     Int       @default(1)

  station          Station           @relation(fields: [stationId], references: [id])
  platforms        Platform[]
  amenities        Amenity[]
  commercialSpaces CommercialSpace[]
  walkingEdgesFrom WalkingEdge[]     @relation("WalkingEdgeFromLevel")
  walkingEdgesTo   WalkingEdge[]     @relation("WalkingEdgeToLevel")

  @@index([stationId])
  @@index([name])
  @@map("levels")
}

model Platform {
  id                 String         @id @default(uuid()) @db.Uuid
  levelId            String         @db.Uuid
  lineId             String         @db.Uuid
  platformNumber     String
  towardsStationId   String         @db.Uuid
  length             Float?
  screenDoors        Boolean        @default(false)
  wheelchairBoarding Boolean        @default(false)
  status             PlatformStatus @default(ACTIVE)
  isActive           Boolean        @default(true)
  deletedAt          DateTime?      @db.Timestamptz
  createdAt          DateTime       @default(now()) @db.Timestamptz
  updatedAt          DateTime       @updatedAt @db.Timestamptz
  version            Int            @default(1)

  level            Level         @relation(fields: [levelId], references: [id])
  line             Line          @relation(fields: [lineId], references: [id])
  towardsStation   Station       @relation("PlatformTowardsStation", fields: [towardsStationId], references: [id])
  interchangesFrom Interchange[] @relation("InterchangeFromPlatform")
  interchangesTo   Interchange[] @relation("InterchangeToPlatform")
  walkingEdgesFrom WalkingEdge[] @relation("WalkingEdgeFromPlatform")
  walkingEdgesTo   WalkingEdge[] @relation("WalkingEdgeToPlatform")

  @@index([levelId])
  @@index([lineId])
  @@index([towardsStationId])
  @@map("platforms")
}

model Interchange {
  id               String    @id @default(uuid()) @db.Uuid
  fromPlatformId   String    @db.Uuid
  toPlatformId     String    @db.Uuid
  walkingDistance  Float
  walkingTime      Int
  accessible       Boolean   @default(false)
  verticalMovement Boolean   @default(false)
  isActive         Boolean   @default(true)
  deletedAt        DateTime? @db.Timestamptz
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz
  version          Int       @default(1)

  fromPlatform Platform @relation("InterchangeFromPlatform", fields: [fromPlatformId], references: [id])
  toPlatform   Platform @relation("InterchangeToPlatform", fields: [toPlatformId], references: [id])

  @@index([fromPlatformId])
  @@index([toPlatformId])
  @@map("interchanges")
}

model Entrance {
  id          String                   @id @default(uuid()) @db.Uuid
  stationId   String                   @db.Uuid
  name        String
  latitude    Float
  longitude   Float
  geom        Unsupported("geometry(Point, 4326)")?
  parking     Boolean                  @default(false)
  lift        Boolean                  @default(false)
  escalator   Boolean                  @default(false)
  accessible  Boolean                  @default(false)
  openingTime String?
  closingTime String?
  isActive    Boolean                  @default(true)
  deletedAt   DateTime?                @db.Timestamptz
  createdAt   DateTime                 @default(now()) @db.Timestamptz
  updatedAt   DateTime                 @updatedAt @db.Timestamptz
  version     Int                      @default(1)

  station          Station       @relation(fields: [stationId], references: [id])
  walkingEdgesFrom WalkingEdge[] @relation("WalkingEdgeFromEntrance")
  walkingEdgesTo   WalkingEdge[] @relation("WalkingEdgeToEntrance")

  @@index([stationId])
  @@index([name])
  @@map("entrances")
}

model Amenity {
  id        String                   @id @default(uuid()) @db.Uuid
  stationId String                   @db.Uuid
  levelId   String                   @db.Uuid
  type      AmenityType
  name      String
  latitude  Float?
  longitude Float?
  geom      Unsupported("geometry(Point, 4326)")?
  status    String
  isActive  Boolean                  @default(true)
  deletedAt DateTime?                @db.Timestamptz
  createdAt DateTime                 @default(now()) @db.Timestamptz
  updatedAt DateTime                 @updatedAt @db.Timestamptz
  version   Int                      @default(1)

  station Station @relation(fields: [stationId], references: [id])
  level   Level   @relation(fields: [levelId], references: [id])

  @@index([stationId])
  @@index([levelId])
  @@index([name])
  @@map("amenities")
}

model CommercialSpace {
  id        String                 @id @default(uuid()) @db.Uuid
  stationId String                 @db.Uuid
  levelId   String                 @db.Uuid
  unitNumber String
  area      Float?
  status    CommercialSpaceStatus  @default(VACANT)
  latitude  Float?
  longitude Float?
  geom      Unsupported("geometry(Point, 4326)")?
  isActive  Boolean                @default(true)
  deletedAt DateTime?              @db.Timestamptz
  createdAt DateTime               @default(now()) @db.Timestamptz
  updatedAt DateTime               @updatedAt @db.Timestamptz
  version   Int                    @default(1)

  station Station            @relation(fields: [stationId], references: [id])
  level   Level              @relation(fields: [levelId], references: [id])
  outlets CommercialOutlet[]

  @@index([stationId])
  @@index([levelId])
  @@index([unitNumber])
  @@map("commercial_spaces")
}

model CommercialOutlet {
  id                String    @id @default(uuid()) @db.Uuid
  commercialSpaceId String    @db.Uuid
  brand             String
  category          String
  openingTime       String?
  closingTime       String?
  averageVisitTime  Int?
  rating            Float?
  isActive          Boolean   @default(true)
  deletedAt         DateTime? @db.Timestamptz
  createdAt         DateTime  @default(now()) @db.Timestamptz
  updatedAt         DateTime  @updatedAt @db.Timestamptz
  version           Int       @default(1)

  commercialSpace CommercialSpace @relation(fields: [commercialSpaceId], references: [id])

  @@index([commercialSpaceId])
  @@index([brand])
  @@map("commercial_outlets")
}

// ----------------- GTFS Ingestion Models & Reserved WalkingEdge -----------------

model Trip {
  id            String    @id @default(uuid()) @db.Uuid
  lineId        String    @db.Uuid
  serviceId     String
  tripId        String    @unique
  tripHeadsign  String?
  directionId   Int?
  shapeId       String?
  isActive      Boolean   @default(true)
  deletedAt     DateTime? @db.Timestamptz
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz
  version       Int       @default(1)

  line        Line        @relation(fields: [lineId], references: [id])
  calendar    Calendar?   @relation(fields: [serviceId], references: [serviceId])
  stopTimes   StopTime[]
  frequencies Frequency[]

  @@index([lineId])
  @@index([serviceId])
  @@index([tripId])
  @@index([shapeId])
  @@map("trips")
}

model StopTime {
  id             String    @id @default(uuid()) @db.Uuid
  tripId         String    @db.Uuid
  stationId      String    @db.Uuid
  arrivalTime    String
  departureTime  String
  stopSequence   Int
  stopHeadsign   String?
  pickupType     Int       @default(0)
  dropOffType    Int       @default(0)
  isActive       Boolean   @default(true)
  deletedAt      DateTime? @db.Timestamptz
  createdAt      DateTime  @default(now()) @db.Timestamptz
  updatedAt      DateTime  @updatedAt @db.Timestamptz
  version        Int       @default(1)

  trip    Trip    @relation(fields: [tripId], references: [id])
  station Station @relation(fields: [stationId], references: [id])

  @@unique([tripId, stopSequence])
  @@index([tripId])
  @@index([stationId])
  @@map("stop_times")
}

model Calendar {
  id        String    @id @default(uuid()) @db.Uuid
  systemId  String    @db.Uuid
  serviceId String    @unique
  monday    Boolean
  tuesday   Boolean
  wednesday Boolean
  thursday  Boolean
  friday    Boolean
  saturday  Boolean
  sunday    Boolean
  startDate DateTime  @db.Date
  endDate   DateTime  @db.Date
  isActive  Boolean   @default(true)
  deletedAt DateTime? @db.Timestamptz
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  version   Int       @default(1)

  system     System         @relation(fields: [systemId], references: [id])
  trips      Trip[]
  exceptions CalendarDate[]

  @@index([systemId])
  @@index([serviceId])
  @@map("calendars")
}

model CalendarDate {
  id            String    @id @default(uuid()) @db.Uuid
  calendarId    String    @db.Uuid
  date          DateTime  @db.Date
  exceptionType Int
  isActive      Boolean   @default(true)
  deletedAt     DateTime? @db.Timestamptz
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz
  version       Int       @default(1)

  calendar Calendar @relation(fields: [calendarId], references: [id])

  @@index([calendarId])
  @@map("calendar_dates")
}

model Shape {
  id           String                   @id @default(uuid()) @db.Uuid
  systemId     String                   @db.Uuid
  shapeId      String
  latitude     Float
  longitude    Float
  sequence     Int
  distTraveled Float?
  geom         Unsupported("geometry(Point, 4326)")?
  isActive     Boolean                  @default(true)
  deletedAt    DateTime?                @db.Timestamptz
  createdAt    DateTime                 @default(now()) @db.Timestamptz
  updatedAt    DateTime                 @updatedAt @db.Timestamptz
  version      Int                      @default(1)

  system System @relation(fields: [systemId], references: [id])

  @@unique([shapeId, sequence])
  @@index([systemId])
  @@index([shapeId])
  @@map("shapes")
}

model Frequency {
  id          String    @id @default(uuid()) @db.Uuid
  tripId      String    @db.Uuid
  startTime   String
  endTime     String
  headwaySecs Int
  exactTimes  Int       @default(0)
  isActive    Boolean   @default(true)
  deletedAt   DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz
  version     Int       @default(1)

  trip Trip @relation(fields: [tripId], references: [id])

  @@index([tripId])
  @@map("frequencies")
}

model WalkingEdge {
  id               String    @id @default(uuid()) @db.Uuid
  stationId        String    @db.Uuid
  fromLevelId      String?   @db.Uuid
  fromPlatformId   String?   @db.Uuid
  fromEntranceId   String?   @db.Uuid
  toLevelId        String?   @db.Uuid
  toPlatformId     String?   @db.Uuid
  toEntranceId     String?   @db.Uuid
  walkingDistance  Float
  walkingTime      Int
  accessible       Boolean   @default(false)
  verticalMovement Boolean   @default(false)
  isActive         Boolean   @default(true)
  deletedAt        DateTime? @db.Timestamptz
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz
  version          Int       @default(1)

  station      Station   @relation(fields: [stationId], references: [id])
  fromLevel    Level?    @relation("WalkingEdgeFromLevel", fields: [fromLevelId], references: [id])
  toLevel      Level?    @relation("WalkingEdgeToLevel", fields: [toLevelId], references: [id])
  fromPlatform Platform? @relation("WalkingEdgeFromPlatform", fields: [fromPlatformId], references: [id])
  toPlatform   Platform? @relation("WalkingEdgeToPlatform", fields: [toPlatformId], references: [id])
  fromEntrance Entrance? @relation("WalkingEdgeFromEntrance", fields: [fromEntranceId], references: [id])
  toEntrance   Entrance? @relation("WalkingEdgeToEntrance", fields: [toEntranceId], references: [id])

  @@index([stationId])
  @@index([fromLevelId])
  @@index([toLevelId])
  @@index([fromPlatformId])
  @@index([toPlatformId])
  @@index([fromEntranceId])
  @@index([toEntranceId])
  @@map("walking_edges")
}

enum ImportSessionStatus {
  PENDING
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum ImportErrorSeverity {
  WARNING
  ERROR
  CRITICAL
}

model ImportSession {
  id               String              @id @default(uuid()) @db.Uuid
  systemId         String              @db.Uuid
  type             String              // e.g. "GTFS_STATIC"
  filename         String
  status           ImportSessionStatus @default(PENDING)
  startedAt        DateTime            @default(now()) @db.Timestamptz
  finishedAt       DateTime?           @db.Timestamptz
  duration         Int?                // In milliseconds
  recordsProcessed Int                 @default(0)
  recordsInserted  Int                 @default(0)
  recordsUpdated   Int                 @default(0)
  recordsDeleted   Int                 @default(0)
  recordsSkipped   Int                 @default(0)
  errorsCount      Int                 @default(0)
  warningsCount    Int                 @default(0)
  report           Json?
  isActive         Boolean             @default(true)
  deletedAt        DateTime?           @db.Timestamptz
  createdAt        DateTime            @default(now()) @db.Timestamptz
  updatedAt        DateTime            @updatedAt @db.Timestamptz
  version          Int                 @default(1)

  system           System              @relation(fields: [systemId], references: [id])
  errors           ImportError[]
  audits           ImportAudit[]

  @@index([systemId])
  @@map("import_sessions")
}

model ImportError {
  id         String              @id @default(uuid()) @db.Uuid
  sessionId  String              @db.Uuid
  file       String
  line       Int?
  message    String
  severity   ImportErrorSeverity @default(ERROR)
  rawData    String?
  isActive   Boolean             @default(true)
  deletedAt  DateTime?           @db.Timestamptz
  createdAt  DateTime            @default(now()) @db.Timestamptz
  updatedAt  DateTime            @updatedAt @db.Timestamptz
  version    Int                 @default(1)

  session    ImportSession       @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@map("import_errors")
}

model ImportAudit {
  id         String        @id @default(uuid()) @db.Uuid
  sessionId  String        @db.Uuid
  entity     String        // e.g. "Agency", "Station"
  operation  String        // e.g. "INSERT", "UPDATE", "DELETE"
  count      Int
  isActive   Boolean       @default(true)
  deletedAt  DateTime?     @db.Timestamptz
  createdAt  DateTime      @default(now()) @db.Timestamptz
  updatedAt  DateTime      @updatedAt @db.Timestamptz
  version    Int           @default(1)

  session    ImportSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@map("import_audits")
}

